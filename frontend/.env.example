# Frontend environment (Vite exposes only VITE_*-prefixed vars to the client)

# Base URL of the backend API. In local dev leave it as /api to use the Vite
# proxy; in production set the full URL of your deployed backend.
VITE_API_URL=/api

# Base origin for the WebSocket connection. Empty = same origin (uses the Vite
# proxy in dev). In production set e.g. https://your-api.onrender.com
VITE_SOCKET_URL=

VITE_APP_NAME=Vutto Auctions

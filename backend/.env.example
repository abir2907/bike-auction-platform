# ──────────────────────────────────────────────────────────────────────────
# Vutto Auctions — Backend environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development                 # development | test | production
PORT=4000                            # Port the HTTP/WS server listens on
APP_NAME=Vutto Auctions

# Public URLs (used for CORS, emails, password-reset links)
CLIENT_URL=http://localhost:5173     # Frontend origin allowed by CORS
API_PUBLIC_URL=http://localhost:4000 # Public base URL of this API

# Database — Neon/Postgres connection string (use the POOLED url in production)
# Example (Neon): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vutto?schema=public

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=15m                   # Access token lifetime (short-lived)
JWT_REFRESH_TTL=7d                   # Refresh token lifetime (long-lived)

# Cookies
COOKIE_DOMAIN=                        # leave empty for localhost; set in prod e.g. .yourdomain.com
COOKIE_SECURE=false                   # true in production (HTTPS only)

# Password hashing
BCRYPT_SALT_ROUNDS=12

# Rate limiting (per IP, per window)
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes
RATE_LIMIT_MAX=300                    # general API requests per window
AUTH_RATE_LIMIT_MAX=20                # stricter limit for auth endpoints

# Auctions
AUCTION_TICK_MS=5000                  # how often the lifecycle scheduler runs
AUCTION_ANTISNIPE_SECONDS=30          # default anti-snipe window (extends auction)

# SMTP (email). In development leave empty to log emails to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Vutto Auctions <no-reply@vutto.local>"

# Observability
LOG_LEVEL=info                        # trace|debug|info|warn|error
METRICS_ENABLED=true                  # expose Prometheus metrics at /metrics

# Seed admin (used by `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@vutto.local
SEED_ADMIN_PASSWORD=Admin@12345
